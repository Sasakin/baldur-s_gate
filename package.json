{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "tsx server.ts",
    "start": "NODE_ENV=production tsx server.ts",
    "build": "pnpm run typecheck && pnpm -r --if-present run build && vite build",
    "lint": "pnpm run typecheck",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^5.0.0",
    "@types/node": "^25.3.3",
    "@vitejs/plugin-react": "^5.0.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vite": "^7.3.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@types/three": "^0.184.0",
    "express": "^5.0.1",
    "lucide-react": "^0.545.0",
    "motion": "^12.35.1",
    "pnpm": "^10.33.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "three": "^0.184.0"
  }
}
